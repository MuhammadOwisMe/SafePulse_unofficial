{
  "expo": {
    "name": "SafePulse",
    "slug": "safepulse-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safepulse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safepulse.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafePulse needs your location to show live safety incidents and send emergency alerts to your trusted contacts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafePulse uses your location to keep your trusted contacts updated during an emergency."
      }
    },
    "android": {
      "package": "com.safepulse.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "INTERNET",
        "SEND_SMS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAxbp8i-pZ0Rx3spqANg5llCYE8_WNDJMA"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#161E2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow SafePulse to access your location always for emergency tracking.",
          "locationWhenInUsePermission": "Allow SafePulse to access your location while using the app."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#161E2E"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
